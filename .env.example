# Database (Neon)
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-1.aws.neon.tech/crionna?sslmode=require

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Cloudflare R2
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET_NAME=crionna-images
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# Firecrawl
FIRECRAWL_API_KEY=fc-...

# GitHub App (ingestion log commits)
# App ID from: github.com/settings/apps/your-app-name
GITHUB_APP_ID=123456
# Base64-encoded PEM private key (see setup docs)
GITHUB_APP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...
# Installation ID from: github.com/settings/installations
GITHUB_APP_INSTALLATION_ID=12345678
GITHUB_LOG_REPO_OWNER=your-github-username
GITHUB_LOG_REPO_NAME=crionna-ingestion-log

# Auth.js
# Generate with: openssl rand -base64 33
AUTH_SECRET=replace-with-32-plus-char-random-string
AUTH_EMAIL_FROM=crionna@yourdomain.com

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
